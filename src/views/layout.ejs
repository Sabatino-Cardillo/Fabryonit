<!DOCTYPE html>
<html lang="it">

<head>
  <meta charset="UTF-8">
  <title>FabryonIt</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      -webkit-user-select: none;
      -webkit-user-drag: none;
      user-select: none;
    }

    body,
    html {
      height: 100%;
      margin: 0;
      padding: 0;
    }

    body {
      display: flex;
      flex-direction: column;
      background: #fcfcfc;
    }

    .sidebar {
      width: 260px;
      min-height: 95vh;
      background: #2c3e50;
      color: white;
      padding: 0;
      font-size: 14px;
      position: relative;
    }

    .sidebar::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      background: #3498db;
    }

    .logo-container {
      padding: 2rem 1.5rem;
      text-align: center;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .sidebar .logo {
      max-width: 160px;
      display: block;
      margin: 0 auto;
      transition: opacity 0.3s ease;
    }

    .sidebar .logo:hover {
      opacity: 0.9;
    }

    /* ⭐ MODIFICATO: Reso cliccabile */
    .user-info {
      padding: 1.5rem;
      background: rgba(0, 0, 0, 0.15);
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      display: flex;
      align-items: center;
      gap: 1rem;
      cursor: pointer;
      transition: background 0.2s ease;
      text-decoration: none;
      color: white;
    }

    .user-info:hover {
      background: rgba(0, 0, 0, 0.25);
    }

    .user-avatar {
      width: 45px;
      height: 45px;
      background: #34495e;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.3rem;
      border: 2px solid rgba(255, 255, 255, 0.1);
    }

    .user-details {
      flex: 1;
    }

    .user-details p {
      margin: 0;
      font-size: 0.95rem;
      font-weight: 600;
      color: white;
    }

    .user-role {
      font-size: 0.75rem;
      color: rgba(255, 255, 255, 0.6);
      margin-top: 0.15rem;
    }

    /* ⭐ AGGIUNTO: Icona freccia */
    .user-info .profile-arrow {
      font-size: 1rem;
      opacity: 0.6;
      transition: transform 0.2s, opacity 0.2s;
    }

    .user-info:hover .profile-arrow {
      opacity: 1;
      transform: translateX(3px);
    }

    .nav-section {
      padding: 1.5rem 1rem;
    }

    .nav-section-title {
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: rgba(255, 255, 255, 0.5);
      margin-bottom: 0.75rem;
      padding-left: 0.5rem;
      font-weight: 600;
    }

    .sidebar .nav-link {
      color: rgba(255, 255, 255, 0.85);
      margin-bottom: 0.4rem;
      border-radius: 8px;
      padding: 0.75rem 1rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      transition: all 0.2s ease;
      position: relative;
    }

    .sidebar .nav-link::before {
      content: '';
      position: absolute;
      left: 0;
      top: 50%;
      transform: translateY(-50%);
      width: 3px;
      height: 0;
      background: #3498db;
      transition: height 0.2s ease;
    }

    .sidebar .nav-link:hover {
      background: rgba(52, 152, 219, 0.15);
      color: white;
      padding-left: 1.2rem;
    }

    .sidebar .nav-link:hover::before {
      height: 60%;
    }

    .sidebar .nav-link.active {
      background: rgba(52, 152, 219, 0.2);
      color: white;
      font-weight: 600;
      padding-left: 1.2rem;
    }

    .sidebar .nav-link.active::before {
      height: 60%;
    }

    .nav-link i {
      font-size: 1.15rem;
      width: 22px;
      text-align: center;
    }

    .content {
      flex-grow: 1;
      padding: 2rem;
    }

    footer {
      background: #2c3e50;
      color: rgba(255, 255, 255, 0.8);
      padding: 1.5rem 0;
      text-align: center;
    }

    footer p {
      margin: 0;
      font-size: 0.85rem;
    }

    .nav-item {
      list-style: none;
    }

    /* Scrollbar personalizzata per la sidebar */
    .sidebar::-webkit-scrollbar {
      width: 6px;
    }

    .sidebar::-webkit-scrollbar-track {
      background: rgba(255, 255, 255, 0.05);
    }

    .sidebar::-webkit-scrollbar-thumb {
      background: rgba(255, 255, 255, 0.2);
      border-radius: 3px;
    }

    .sidebar::-webkit-scrollbar-thumb:hover {
      background: rgba(255, 255, 255, 0.3);
    }

    /* Badge notifiche */
    .badge-notifica {
      background: #e74c3c;
      color: white;
      padding: 0.2rem 0.5rem;
      border-radius: 10px;
      font-size: 0.75rem;
      font-weight: 700;
      margin-left: auto;
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.1); }
    }

    .nav-link {
      display: flex;
      align-items: center;
      position: relative;
    }

  </style>
</head>


<body>

  <div class="d-flex">

    <nav class="sidebar d-flex flex-column">

      <div class="logo-container">
        <img src="../img/logo3.png" alt="Logo FabryonIt" class="logo">
      </div>

      <!-- ⭐ MODIFICATO: Reso link a /profile -->
      <a href="/profile" class="user-info" style="text-decoration: none;">
        <div class="user-avatar">
          <i class="bi bi-person-fill"></i>
        </div>
        <div class="user-details">
          <p><%= nomeUtente %></p>
          <div class="user-role">Amministratore</div>
        </div>
        <i class="bi bi-chevron-right profile-arrow"></i>
      </a>

      <div class="nav-section">
        <div class="nav-section-title">Navigazione</div>
        <ul class="nav flex-column w-100">
          <li class="nav-item">
            <a class="nav-link" href="/">
              <i class="bi bi-pie-chart-fill"></i>
              <span>Dashboard</span>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/clienti">
              <i class="bi bi-people-fill"></i>
              <span>Clienti</span>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/prodotti">
              <i class="bi bi-box-seam-fill"></i>
              <span>Prodotti</span>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/dipendenti">
              <i class="bi bi-laptop"></i>
              <span>Dipendenti</span>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/bolle">
              <i class="bi bi-file-earmark-text-fill"></i>
              <span>Bolle</span>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/merce">
              <i class="bi bi-tag-fill"></i>
              <span>Merce</span>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/storico-bolle">
              <i class="bi bi-archive-fill"></i>
              <span>Storico Bolle</span>
            </a>
          </li>
          <li class="nav-item">
    <a class="nav-link" href="/conteggio-produzione">
        <i class="bi bi-calculator-fill"></i>
        <span>Conteggio Produzione</span>
    </a>
</li>
        </ul>
      </div>

      <div class="nav-section" style="margin-top: auto; padding-top: 0;">
        <div class="nav-section-title">Sistema</div>
        <ul class="nav flex-column w-100">
          <li class="nav-item">
            <a class="nav-link" href="/assistenza">
              <i class="bi bi-headset"></i>
              <span>Assistenza</span>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/notifiche" id="notifiche-link">
              <i class="bi bi-bell-fill"></i>
              <span>Notifiche</span>
              <span id="notifiche-badge" class="badge-notifica" style="display: none;">0</span>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/settings">
              <i class="bi bi-gear-fill"></i>
              <span>Impostazioni</span>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/logout">
              <i class="bi bi-box-arrow-right"></i>
              <span>Esci</span>
            </a>
          </li>
        </ul>
      </div>

    </nav>

    <div class="content">
      <%- body %>
    </div>

  </div>

  <footer>
    <p class="mb-0">© 2025 FabryonIt - Creato da Sabatino Cardillo. Tutti i diritti riservati.</p>
  </footer>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const currentPath = window.location.href;
      const navLinks = document.querySelectorAll('.sidebar .nav-link');

      navLinks.forEach(link => {
        if (currentPath.includes(link.getAttribute('href')) && link.getAttribute('href') !== '/') {
          link.classList.add('active');
        } else if (link.getAttribute('href') === '/' && currentPath.endsWith('/')) {
          link.classList.add('active');
        }
      });

      // Aggiorna badge notifiche ogni 10 secondi
      function updateNotificheBadge() {
        fetch('/notifiche/count')
          .then(res => res.json())
          .then(data => {
            const badge = document.getElementById('notifiche-badge');
            if (data.count > 0) {
              badge.textContent = data.count;
              badge.style.display = 'inline-block';
            } else {
              badge.style.display = 'none';
            }
          })
          .catch(err => console.error('Errore aggiornamento notifiche:', err));
      }

      // Prima chiamata immediata
      updateNotificheBadge();

      // Poi ogni 10 secondi
      setInterval(updateNotificheBadge, 10000);
    });
  </script>
</body>

</html>
<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Ticket #<%= ticket.id %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            background: #f8f9fa;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        .admin-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 1.5rem 0;
            margin-bottom: 2rem;
        }

        .btn-back {
            color: white;
            text-decoration: none;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .ticket-grid {
            display: grid;
            grid-template-columns: 350px 1fr;
            gap: 2rem;
        }

        .sidebar-card {
            background: white;
            border-radius: 12px;
            padding: 1.5rem;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            height: fit-content;
        }

        .sidebar-section {
            margin-bottom: 2rem;
        }

        .sidebar-section:last-child {
            margin-bottom: 0;
        }

        .sidebar-title {
            font-weight: 600;
            color: #2c3e50;
            margin-bottom: 1rem;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid #f0f0f0;
        }

        .info-item {
            display: flex;
            justify-content: space-between;
            padding: 0.75rem 0;
            border-bottom: 1px solid #f8f9fa;
        }

        .info-label {
            color: #7f8c8d;
            font-weight: 600;
        }

        .info-value {
            color: #2c3e50;
        }

        .form-select {
            width: 100%;
            padding: 0.5rem;
            border: 2px solid #e0e0e0;
            border-radius: 6px;
            margin-bottom: 1rem;
        }

        .btn-update {
            width: 100%;
            padding: 0.75rem;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
        }

        .btn-delete {
            width: 100%;
            padding: 0.75rem;
            background: #e74c3c;
            color: white;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 1rem;
        }

        .chat-container {
            background: white;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
            overflow: hidden;
        }

        .chat-header {
            background: #f8f9fa;
            padding: 1.5rem;
            border-bottom: 2px solid #e0e0e0;
        }

        .chat-header h3 {
            margin: 0;
            color: #2c3e50;
        }

        .chat-messages {
            padding: 2rem;
            max-height: 600px;
            overflow-y: auto;
        }

        .message {
            margin-bottom: 1.5rem;
            display: flex;
            gap: 1rem;
        }

        .message-avatar {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            flex-shrink: 0;
        }

        .message-cliente .message-avatar {
            background: #e3f2fd;
            color: #1565c0;
        }

        .message-admin .message-avatar {
            background: #f3e5f5;
            color: #7b1fa2;
        }

        .message-content {
            flex: 1;
        }

        .message-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 0.5rem;
        }

        .message-author {
            font-weight: 600;
            color: #2c3e50;
        }

        .message-time {
            font-size: 0.85rem;
            color: #95a5a6;
        }

        .message-text {
            background: #f8f9fa;
            padding: 1rem;
            border-radius: 8px;
            line-height: 1.6;
        }

        .message-admin .message-text {
            background: #fff3e0;
        }

        .chat-input {
            padding: 1.5rem;
            border-top: 2px solid #e0e0e0;
        }

        .input-form textarea {
            width: 100%;
            padding: 0.75rem;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            resize: vertical;
            min-height: 100px;
            margin-bottom: 1rem;
        }

        .btn-send {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 0.75rem 2rem;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
        }

        .badge {
            padding: 0.4rem 0.8rem;
            border-radius: 6px;
            font-size: 0.85rem;
            font-weight: 600;
        }

        .badge-aperto { background: #fff3cd; color: #856404; }
        .badge-in_lavorazione { background: #d1ecf1; color: #0c5460; }
        .badge-risolto { background: #d4edda; color: #155724; }
        .badge-chiuso { background: #e2e3e5; color: #383d41; }

        @media (max-width: 992px) {
            .ticket-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="admin-header">
        <div class="container">
            <a href="/admin/tickets" class="btn-back">
                <i class="bi bi-arrow-left"></i> Torna ai ticket
            </a>
        </div>
    </div>

    <div class="container">
        <div class="ticket-grid">
            <!-- Sidebar Info -->
            <div class="sidebar-card">
                <div class="sidebar-section">
                    <div class="sidebar-title">
                        <i class="bi bi-info-circle"></i> Informazioni Ticket
                    </div>
                    <div class="info-item">
                        <span class="info-label">ID:</span>
                        <span class="info-value">#<%= ticket.id %></span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Stato:</span>
                        <span class="badge badge-<%= ticket.stato %>">
                            <%= ticket.stato.replace('_', ' ') %>
                        </span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Priorità:</span>
                        <span class="info-value text-capitalize"><%= ticket.priorita %></span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Categoria:</span>
                        <span class="info-value text-capitalize"><%= ticket.categoria %></span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Creato:</span>
                        <span class="info-value"><%= new Date(ticket.data_creazione).toLocaleDateString('it-IT') %></span>
                    </div>
                </div>

                <div class="sidebar-section">
                    <div class="sidebar-title">
                        <i class="bi bi-building"></i> Cliente
                    </div>
                    <div class="info-item">
                        <span class="info-label">Azienda:</span>
                        <span class="info-value"><%= ticket.ragione_sociale %></span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Username:</span>
                        <span class="info-value">@<%= ticket.username %></span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Email:</span>
                        <span class="info-value"><%= ticket.email %></span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Telefono:</span>
                        <span class="info-value"><%= ticket.telefono %></span>
                    </div>
                </div>

                <div class="sidebar-section">
                    <div class="sidebar-title">
                        <i class="bi bi-sliders"></i> Gestione
                    </div>
                    <form action="/admin/tickets/<%= ticket.id %>/stato" method="POST">
                        <label style="font-weight: 600; margin-bottom: 0.5rem; display: block;">Cambia Stato:</label>
                        <select name="stato" class="form-select">
                            <option value="aperto" <%= ticket.stato === 'aperto' ? 'selected' : '' %>>Aperto</option>
                            <option value="in_lavorazione" <%= ticket.stato === 'in_lavorazione' ? 'selected' : '' %>>In Lavorazione</option>
                            <option value="risolto" <%= ticket.stato === 'risolto' ? 'selected' : '' %>>Risolto</option>
                            <option value="chiuso" <%= ticket.stato === 'chiuso' ? 'selected' : '' %>>Chiuso</option>
                        </select>
                        <button type="submit" class="btn-update">
                            <i class="bi bi-check-circle"></i> Aggiorna Stato
                        </button>
                    </form>

                    <form action="/admin/tickets/<%= ticket.id %>/elimina" method="POST" 
                          onsubmit="return confirm('Sei sicuro di voler eliminare questo ticket?')">
                        <button type="submit" class="btn-delete">
                            <i class="bi bi-trash"></i> Elimina Ticket
                        </button>
                    </form>
                </div>
            </div>

            <!-- Chat -->
            <div class="chat-container">
                <div class="chat-header">
                    <h3><i class="bi bi-chat-dots"></i> <%= ticket.oggetto %></h3>
                </div>

                <div class="chat-messages">
                    <% messaggi.forEach(msg => { %>
                        <div class="message message-<%= msg.mittente_tipo %>">
                            <div class="message-avatar">
                                <i class="bi <%= msg.mittente_tipo === 'cliente' ? 'bi-person-fill' : 'bi-headset' %>"></i>
                            </div>
                            <div class="message-content">
                                <div class="message-header">
                                    <span class="message-author">
                                        <%= msg.mittente_tipo === 'cliente' ? ticket.ragione_sociale : 'Assistenza' %>
                                    </span>
                                    <span class="message-time">
                                        <%= new Date(msg.data_invio).toLocaleString('it-IT') %>
                                    </span>
                                </div>
                                <div class="message-text">
                                    <%= msg.messaggio %>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <div class="chat-input">
                    <form action="/admin/tickets/<%= ticket.id %>/risposta" method="POST" class="input-form">
                        <textarea name="messaggio" placeholder="Scrivi una risposta..." required></textarea>
                        <button type="submit" class="btn-send">
                            <i class="bi bi-send"></i> Invia Risposta
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Auto-scroll alla fine dei messaggi
        const chatMessages = document.querySelector('.chat-messages');
        chatMessages.scrollTop = chatMessages.scrollHeight;
    </script>
</body>
</html>
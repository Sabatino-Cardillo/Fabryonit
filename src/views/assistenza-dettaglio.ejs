<% layout('layout') %>

<style>
    .dettaglio-container {
        max-width: 900px;
        margin: 0 auto;
    }

    .ticket-info-card {
        background: white;
        padding: 2rem;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        margin-bottom: 2rem;
    }

    .ticket-info-header {
        display: flex;
        justify-content: space-between;
        align-items: start;
        margin-bottom: 1.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 2px solid #f0f0f0;
    }

    .ticket-info-title h2 {
        color: #2c3e50;
        font-size: 1.5rem;
        margin-bottom: 0.5rem;
    }

    .ticket-info-id {
        color: #95a5a6;
        font-size: 0.9rem;
    }

    .ticket-badges {
        display: flex;
        gap: 0.5rem;
    }

    .badge {
        padding: 0.5rem 1rem;
        border-radius: 6px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .badge-aperto { background: #fff3cd; color: #856404; }
    .badge-in_lavorazione { background: #d1ecf1; color: #0c5460; }
    .badge-risolto { background: #d4edda; color: #155724; }
    .badge-chiuso { background: #e2e3e5; color: #383d41; }

    .ticket-meta {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: #7f8c8d;
        font-size: 0.9rem;
    }

    .meta-item i {
        font-size: 1.1rem;
        color: #667eea;
    }

    .chat-container {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }

    .chat-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 1.5rem;
        font-weight: 600;
    }

    .chat-messages {
        padding: 2rem;
        max-height: 500px;
        overflow-y: auto;
    }

    .message {
        margin-bottom: 1.5rem;
        display: flex;
        gap: 1rem;
    }

    .message-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        flex-shrink: 0;
    }

    .message-cliente .message-avatar {
        background: #e3f2fd;
        color: #1565c0;
    }

    .message-admin .message-avatar {
        background: #f3e5f5;
        color: #7b1fa2;
    }

    .message-content {
        flex: 1;
    }

    .message-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.5rem;
    }

    .message-author {
        font-weight: 600;
        color: #2c3e50;
    }

    .message-time {
        font-size: 0.8rem;
        color: #95a5a6;
    }

    .message-text {
        background: #f8f9fa;
        padding: 1rem;
        border-radius: 8px;
        color: #2c3e50;
        line-height: 1.6;
    }

    .message-admin .message-text {
        background: #fff3e0;
    }

    .chat-input {
        padding: 1.5rem;
        border-top: 1px solid #e0e0e0;
    }

    .input-form {
        display: flex;
        gap: 1rem;
    }

    .input-form textarea {
        flex: 1;
        padding: 0.75rem;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        resize: none;
        font-size: 0.95rem;
    }

    .input-form textarea:focus {
        outline: none;
        border-color: #667eea;
    }

    .btn-send {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 0.75rem 1.5rem;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.2s;
    }

    .btn-send:hover {
        transform: translateY(-2px);
    }

    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: #667eea;
        text-decoration: none;
        margin-bottom: 1.5rem;
        font-weight: 600;
    }

    .btn-back:hover {
        color: #764ba2;
    }

    @media (max-width: 768px) {
        .ticket-meta {
            grid-template-columns: 1fr;
        }

        .ticket-info-header {
            flex-direction: column;
            gap: 1rem;
        }
    }
</style>

<div class="dettaglio-container">
    <a href="/assistenza" class="btn-back">
        <i class="bi bi-arrow-left"></i> Torna ai ticket
    </a>

    <div class="ticket-info-card">
        <div class="ticket-info-header">
            <div class="ticket-info-title">
                <h2><%= ticket.oggetto %></h2>
                <div class="ticket-info-id">Ticket #<%= ticket.id %></div>
            </div>
            <div class="ticket-badges">
                <span class="badge badge-<%= ticket.stato %>">
                    <%= ticket.stato.replace('_', ' ').toUpperCase() %>
                </span>
            </div>
        </div>

        <div class="ticket-meta">
            <div class="meta-item">
                <i class="bi bi-calendar"></i>
                <span>Creato: <%= new Date(ticket.data_creazione).toLocaleDateString('it-IT') %></span>
            </div>
            <div class="meta-item">
                <i class="bi bi-tag"></i>
                <span>Categoria: <%= ticket.categoria %></span>
            </div>
            <div class="meta-item">
                <i class="bi bi-flag"></i>
                <span>Priorità: <%= ticket.priorita %></span>
            </div>
        </div>
    </div>

    <div class="chat-container">
        <div class="chat-header">
            <i class="bi bi-chat-dots"></i> Conversazione
        </div>

        <div class="chat-messages">
            <% messaggi.forEach(msg => { %>
                <div class="message message-<%= msg.mittente_tipo %>">
                    <div class="message-avatar">
                        <i class="bi <%= msg.mittente_tipo === 'cliente' ? 'bi-person-fill' : 'bi-headset' %>"></i>
                    </div>
                    <div class="message-content">
                        <div class="message-header">
                            <span class="message-author">
                                <%= msg.mittente_tipo === 'cliente' ? 'Tu' : 'Assistenza' %>
                            </span>
                            <span class="message-time">
                                <%= new Date(msg.data_invio).toLocaleString('it-IT') %>
                            </span>
                        </div>
                        <div class="message-text">
                            <%= msg.messaggio %>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>

        <% if (ticket.stato !== 'chiuso') { %>
            <div class="chat-input">
                <form action="/assistenza/<%= ticket.id %>/messaggio" method="POST" class="input-form">
                    <textarea name="messaggio" rows="3" placeholder="Scrivi un messaggio..." required></textarea>
                    <button type="submit" class="btn-send">
                        <i class="bi bi-send"></i> Invia
                    </button>
                </form>
            </div>
        <% } else { %>
            <div class="chat-input" style="text-align: center; color: #7f8c8d;">
                <i class="bi bi-lock"></i> Questo ticket è stato chiuso
            </div>
        <% } %>
    </div>
</div>

<script>
    // Auto-scroll alla fine dei messaggi
    const chatMessages = document.querySelector('.chat-messages');
    chatMessages.scrollTop = chatMessages.scrollHeight;
</script>